source ~/.config/fish/functions.fish

if status is-interactive
    # Commands to run in interactive sessions can go here
end

set -U fish_greeting

fish_vi_key_bindings
starship init fish | source
fnm env --use-on-cd --shell fish | source

set -x XDG_CONFIG_HOME $HOME/.config
set -gx EDITOR nvim
{{ if eq .chezmoi.os "darwin" }}
fish_add_path /opt/homebrew/opt/ruby/bin
fish_add_path /opt/homebrew/lib/ruby/gems/4.0.0/bin
{{ end }}

fish_add_path ~/.cargo/bin

{{ if eq .chezmoi.os "linux" }}

if status is-interactive
    and not set -q TMUX
    if test "$DISPLAY" = ":0"
        # VNC / local desktop session
        set SESSION_NAME vnc
    else
        # SSH session
        set SESSION_NAME home
    end

    if tmux has-session -t $SESSION_NAME
        exec tmux attach-session -t $SESSION_NAME
    else
        tmux new-session -s $SESSION_NAME
    end
end

set -g -x SYSTEMD_EDITOR vim
set -g -x SSH_AUTH_SOCK $XDG_RUNTIME_DIR/ssh-agent.socket
ssh-add -l | grep -q op_signing_key; or ssh-add ~/.ssh/op_signing_key 2>/dev/null
{{ end }}
