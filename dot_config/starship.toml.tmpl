# Per-host accent: each machine gets a distinct color so hosts are
# instantly distinguishable at a glance. Add a host to the map below;
# anything not listed falls back to "default".
{{ $accent := dict
  "tomauty" "#E0AF68"
  "mochi"   "#E8A2B8"
  "default" "#BFA8BF" -}}
{{ $c := get $accent .chezmoi.hostname | default (get $accent "default") }}
# Starship prompt — ported from OMP uew theme
# Line 1: ~ username  branch  shell
# Line 2: ~ path ~

format = """
[~](fg:{{ $c }}) $username$hostname$git_branch$shell
[~](fg:{{ $c }}) $directory$character"""

# No right prompt — we dropped that for speed
right_format = ""

[username]
style_user = "fg:#BBC4B9"
style_root = "fg:#BBC4B9"
format = "[$user ]($style)"
show_always = true

[hostname]
# Show the host name only over SSH, so the local machine stays clean.
ssh_only = true
format = "[$hostname ](fg:{{ $c }})"

[git_branch]
symbol = "\ue725 "
style = "fg:{{ $c }}"
format = "[$symbol$branch]($style) "

[shell]
disabled = false
format = "[\uf120](fg:#fff) [$indicator]($style) "
style = "fg:{{ $c }}"
pwsh_indicator = "pwsh"
bash_indicator = "bash"
fish_indicator = "fish"

[directory]
style = "fg:#B6D6F2"
format = "[\ue5ff $path]($style) "
truncation_length = 0
home_symbol = "home"
fish_style_pwd_dir_length = 0

[character]
success_symbol = "[~](fg:{{ $c }})"
error_symbol = "[~](fg:#fff)"
vimcmd_symbol = "[~](fg:{{ $c }})"
