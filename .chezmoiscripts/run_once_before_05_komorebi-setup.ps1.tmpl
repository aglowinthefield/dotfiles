{{- if ne .chezmoi.os "windows" -}}
{{- else -}}
# Enable long path support (required for komorebi)
$longPathsEnabled = Get-ItemProperty 'HKLM:\SYSTEM\CurrentControlSet\Control\FileSystem' -Name 'LongPathsEnabled' -ErrorAction SilentlyContinue
if (-not $longPathsEnabled -or $longPathsEnabled.LongPathsEnabled -ne 1) {
    Write-Host "Enabling long path support (requires admin)..."
    try {
        Set-ItemProperty 'HKLM:\SYSTEM\CurrentControlSet\Control\FileSystem' -Name 'LongPathsEnabled' -Value 1
        Write-Host "Long path support enabled."
    } catch {
        Write-Host "WARNING: Could not enable long paths. Run this in an Administrator terminal:"
        Write-Host "  Set-ItemProperty 'HKLM:\SYSTEM\CurrentControlSet\Control\FileSystem' -Name 'LongPathsEnabled' -Value 1"
    }
}

# Reminder: disable animations manually for komorebi
Write-Host ""
Write-Host "NOTE: For best komorebi experience, disable system animations:"
Write-Host "  Settings > Accessibility > Visual effects > Animation effects -> Off"
Write-Host ""
{{- end -}}
